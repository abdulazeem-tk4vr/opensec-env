# Remote Ollama (RunPod HTTP proxy or any OpenAI-compatible Ollama server)
# Copy to .env and set your proxy URL — no code changes required.
OLLAMA_BASE_URL=https://your-id.proxy.runpod.net
OLLAMA_MODEL=llama3.2:3b

# Optional defender generation settings
OLLAMA_TEMPERATURE=0.2
OLLAMA_MAX_TOKENS=600

# Local Ollama instead of remote:
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: live attacker on the same Ollama instance (default: mock attacker)
# OPENSEC_ATTACKER_SGLANG=1
# SGLANG_BASE_URL=http://localhost:11434/v1
# OPENSEC_ATTACKER_MODEL=llama3.2:3b
